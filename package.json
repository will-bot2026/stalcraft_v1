{
  "name": "ultimatebuild",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "pnpm web:build && if [ -d apps/web/.vercel/output ]; then rm -rf .vercel/output && mkdir -p .vercel && cp -R apps/web/.vercel/output .vercel/output; fi",
    "web:check": "pnpm --filter @ultimatebuild/web check",
    "web:build": "pnpm --filter @ultimatebuild/web build",
    "discord:bot": "pnpm --filter @ultimatebuild/discord-bot start",
    "optimize": "tsx apps/cli/src/index.ts",
    "market:pull": "node --import tsx scripts/pull-market.ts",
    "market:pull-chunked": "node --import tsx scripts/pull-market-chunked.ts",
    "market:export-snapshot": "node --import tsx scripts/export-market-snapshot.ts",
    "market:debug-artifact": "node --import tsx scripts/debug-artifact-market.ts",
    "market:audit-coverage": "node --import tsx scripts/audit-market-coverage.ts",
    "market:sanity:stalcraftdb": "node --import tsx scripts/sanity-check-stalcraftdb-prices.ts",
    "benchmark:optimizer": "node --import tsx scripts/benchmark-optimizer.ts",
    "benchmark:optimizer:real": "node --import tsx scripts/benchmark-optimizer-real.ts",
    "data:generate": "tsx scripts/generate-normalized-data.ts",
    "data:generate:exbo": "tsx scripts/generate-normalized-data.ts --source exbo --out data/normalized-exbo",
    "data:diff": "tsx scripts/generate-data-diff.ts",
    "assets:sync-icons": "tsx scripts/sync-item-icons.ts"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
